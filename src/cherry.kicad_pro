{
  "meta": {
    "filename": "cherry.kicad_pro",
    "version": 1
  },
  "project": {
    "created": "2026-04-01",
    "updated": "2026-04-01",
    "version": "rev1.0",
    "title": "Cherry FPGA Dev Board",
    "company": "NextMicon"
  },
  "schematic": {
    "drawing": {
      "default_line_width": 6.0,
      "default_text_size": 50.0
    },
    "libraries": {
      "Cherry": {
        "uri": "${KIPRJMOD}/../lib/symbols/Cherry.kicad_sym",
        "type": "KiCad"
      }
    }
  },
  "boards": [],
  "text_variables": {},
  "net_settings": {
    "classes": [
      {
        "name": "Default",
        "clearance": 0.2,
        "trace_width": 0.2,
        "via_diameter": 0.6,
        "via_drill": 0.3
      },
      {
        "name": "Power",
        "clearance": 0.25,
        "trace_width": 0.5,
        "via_diameter": 0.8,
        "via_drill": 0.4,
        "nets": ["+5V", "+3V3", "+1V2", "GND", "VBUS"]
      },
      {
        "name": "USB",
        "clearance": 0.2,
        "trace_width": 0.3,
        "via_diameter": 0.6,
        "via_drill": 0.3,
        "diff_pair_width": 0.3,
        "diff_pair_gap": 0.15,
        "nets": ["USB_DP", "USB_DM"]
      }
    ]
  }
}
