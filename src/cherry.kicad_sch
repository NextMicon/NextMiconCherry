  ;; ================================================================
  ;; TEXT NOTES (Design documentation on schematic)
  ;; ================================================================
  (text "POWER SUPPLY SECTION\nUSB 5V -> FB1 -> AMS1117 -> 3.3V -> AP2112K -> 1.2V"
    (at 30.48 20.32 0) (effects (font (size 2.54 2.54)))
    (uuid "30000001-0000-0000-0000-000000000001")
  )
  (text "FT2232HL - USB Interface\nChannel A: MPSSE (SPI) for FPGA programming\nChannel B: UART for user communication"
    (at 30.48 88.9 0) (effects (font (size 2.54 2.54)))
    (uuid "30000002-0000-0000-0000-000000000001")
  )
  (text "iCE40LP8K-CM81 - FPGA\nVCC=1.2V (core), VCCIO=3.3V (I/O banks)\nSPI boot from W25Q32 flash"
    (at 190.5 88.9 0) (effects (font (size 2.54 2.54)))
    (uuid "30000003-0000-0000-0000-000000000001")
  )
  (text "NET CONNECTIONS (via global labels):\n\nSPI Bus:\n  FT2232H ADBUS0 -> SPI_SCK  -> iCE40 SPI_SCK + Flash CLK\n  FT2232H ADBUS1 -> SPI_MOSI -> iCE40 SPI_SI  + Flash DI\n  FT2232H ADBUS2 -> SPI_MISO -> iCE40 SPI_SO  + Flash DO\n  FT2232H ADBUS3 -> SPI_SS_FLASH -> Flash ~CS\n  FT2232H ADBUS4 -> CRESET_B -> iCE40 CRESET_B\n  FT2232H ADBUS5 -> CDONE    -> iCE40 CDONE\n  FT2232H ADBUS6 -> SPI_SS_FPGA -> iCE40 SPI_SS\n\nUART:\n  FT2232H BDBUS0 (TX) -> iCE40 IOB_41 (GPIO RX)\n  FT2232H BDBUS1 (RX) -> iCE40 IOB_42 (GPIO TX)\n\nClock:\n  12MHz Crystal -> FT2232H OSCI/OSCO\n  FT2232H ACBUS0 (CLKOUT) -> iCE40 GBIN0"
    (at 30.48 228.6 0) (effects (font (size 1.524 1.524)))
    (uuid "30000004-0000-0000-0000-000000000001")
  )
  (text "BOM - Bill of Materials:\n\nU1: FT2232HL (LQFP-64) - Dual USB to UART/SPI\nU2: ICE40LP8K-CM81 (BGA-81) - FPGA 7680 LUTs\nU3: W25Q32JVSSIQ (SOIC-8) - 32Mbit SPI Flash\nU4: AMS1117-3.3 (SOT-223) - 3.3V LDO 1A\nU5: AP2112K-1.2TRG1 (SOT-23-5) - 1.2V LDO 600mA\nY1: ABM8-12.000MHZ-B2-T - 12MHz Crystal\nJ1: USB Type-C Receptacle\nJ2: 2x20 Pin Header (2.54mm)\nFB1: Ferrite Bead 600R@100MHz (0805)\nC1-C8: 100nF MLCC (0402)\nC9-C12: 10uF MLCC (0805)\nC13-C14: 18pF MLCC (0402) - Crystal load caps\nC15: 4.7uF MLCC (0603) - VCCORE decoupling\nR1-R2: 5.1K (0402) - USB CC pull-down\nR3: 12K (0402) - FT2232H REF\nR4: 10K (0402) - CRESET_B pull-up\nR5-R8: 1K (0402) - LED current limiting"
    (at 190.5 228.6 0) (effects (font (size 1.524 1.524)))
    (uuid "30000005-0000-0000-0000-000000000001")
  )

