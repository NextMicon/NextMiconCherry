(kicad_pcb
  (version 20240108)
  (generator "pcbnew")
  (generator_version "8.0")
  (general
    (thickness 1.6)
    (legacy_teardrops no)
  )
  (paper "A4")
  (title_block
    (title "Cherry FPGA Dev Board")
    (company "NextMicon")
    (rev "1.0")
    (date "2026-04-01")
    (comment 1 "50mm x 35mm, 2-layer, 1.6mm FR4")
  )
  (layers
    (0 "F.Cu" signal)
    (31 "B.Cu" signal)
    (32 "B.Adhes" user "B.Adhesive")
    (33 "F.Adhes" user "F.Adhesive")
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user "B.Silkscreen")
    (37 "F.SilkS" user "F.Silkscreen")
    (38 "B.Mask" user)
    (39 "F.Mask" user)
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
    (46 "B.CrtYd" user "B.Courtyard")
    (47 "F.CrtYd" user "F.Courtyard")
    (48 "B.Fab" user)
    (49 "F.Fab" user)
  )
  (setup
    (stackup
      (layer "F.SilkS" (type "Top Silk Screen"))
      (layer "F.Paste" (type "Top Solder Paste"))
      (layer "F.Mask" (type "Top Solder Mask") (thickness 0.01))
      (layer "F.Cu" (type "copper") (thickness 0.035))
      (layer "dielectric 1" (type "core") (thickness 1.51) (material "FR4") (epsilon_r 4.5) (loss_tangent 0.02))
      (layer "B.Cu" (type "copper") (thickness 0.035))
      (layer "B.Mask" (type "Bottom Solder Mask") (thickness 0.01))
      (layer "B.Paste" (type "Bottom Solder Paste"))
      (layer "B.SilkS" (type "Bottom Silk Screen"))
      (copper_finish "HASL with lead")
    )
    (pad_to_mask_clearance 0.05)
    (allow_soldermask_bridges_in_footprints no)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (plot_on_all_layers_selection 0x0000000_00000000)
      (disableapertmacros no)
      (usegerberextensions yes)
      (usegerberattributes yes)
      (usegerberadvancedattributes yes)
      (creategerberjobfile yes)
      (svguseinch no)
      (svgprecision 4)
      (excludeedgelayer yes)
      (plotframeref no)
      (viasonmask no)
      (mode 1)
      (useauxorigin no)
      (hpglpennumber 1)
      (hpglpenspeed 20)
      (hpglpendiameter 15.000000)
      (pdf_front_fp_property_popups yes)
      (pdf_back_fp_property_popups yes)
      (dxfpolygonmode yes)
      (dxfimperialunits yes)
      (dxfusepcbnewfont yes)
      (psnegative no)
      (psa4output no)
      (plotreference yes)
      (plotvalue yes)
      (plotfptext yes)
      (plotinvisibletext no)
      (sketchpadsonfab no)
      (subtractmaskfromsilk no)
      (outputformat 1)
      (mirror no)
      (drillshape 1)
      (scaleselection 1)
      (outputdirectory "../out/")
    )
    (grid_origin 0 0)
  )

  ;; ================================================================
  ;; DESIGN RULES
  ;; ================================================================
  (net_class "Default" ""
    (clearance 0.2)
    (trace_width 0.2)
    (via_diameter 0.6)
    (via_drill 0.3)
    (uvia_diameter 0.3)
    (uvia_drill 0.1)
    (diff_pair_width 0.2)
    (diff_pair_gap 0.15)
  )
  (net_class "Power" "Power traces - wider for current capacity"
    (clearance 0.25)
    (trace_width 0.5)
    (via_diameter 0.8)
    (via_drill 0.4)
  )
  (net_class "USB" "USB differential pair"
    (clearance 0.2)
    (trace_width 0.3)
    (via_diameter 0.6)
    (via_drill 0.3)
    (diff_pair_width 0.3)
    (diff_pair_gap 0.15)
  )

  ;; ================================================================
  ;; NETS
  ;; ================================================================
  (net 0 "")
  (net 1 "GND")
  (net 2 "+5V")
  (net 3 "+3V3")
  (net 4 "+1V2")
  (net 5 "USB_DP")
  (net 6 "USB_DM")
  (net 7 "SPI_SCK")
  (net 8 "SPI_MOSI")
  (net 9 "SPI_MISO")
  (net 10 "SPI_SS_FLASH")
  (net 11 "SPI_SS_FPGA")
  (net 12 "CRESET_B")
  (net 13 "CDONE")
  (net 14 "UART_TX")
  (net 15 "UART_RX")
  (net 16 "XTAL1")
  (net 17 "XTAL2")
  (net 18 "VBUS")
  (net 19 "GPIO_0")
  (net 20 "GPIO_1")
  (net 21 "GPIO_2")
  (net 22 "GPIO_3")
  (net 23 "GPIO_4")
  (net 24 "GPIO_5")
  (net 25 "GPIO_6")
  (net 26 "GPIO_7")
  (net 27 "GPIO_8")
  (net 28 "GPIO_9")

  ;; ================================================================
  ;; BOARD OUTLINE (50mm x 35mm with rounded corners)
  ;; Origin at (100, 80), board extends to (150, 115)
  ;; ================================================================
  (gr_line (start 102 80) (end 148 80)
    (stroke (width 0.1) (type default)) (layer "Edge.Cuts") (uuid "40000001-0000-0000-0000-000000000001"))
  (gr_arc (start 148 80) (mid 149.414 80.586) (end 150 82)
    (stroke (width 0.1) (type default)) (layer "Edge.Cuts") (uuid "40000002-0000-0000-0000-000000000001"))
  (gr_line (start 150 82) (end 150 113)
    (stroke (width 0.1) (type default)) (layer "Edge.Cuts") (uuid "40000003-0000-0000-0000-000000000001"))
  (gr_arc (start 150 113) (mid 149.414 114.414) (end 148 115)
    (stroke (width 0.1) (type default)) (layer "Edge.Cuts") (uuid "40000004-0000-0000-0000-000000000001"))
  (gr_line (start 148 115) (end 102 115)
    (stroke (width 0.1) (type default)) (layer "Edge.Cuts") (uuid "40000005-0000-0000-0000-000000000001"))
  (gr_arc (start 102 115) (mid 100.586 114.414) (end 100 113)
    (stroke (width 0.1) (type default)) (layer "Edge.Cuts") (uuid "40000006-0000-0000-0000-000000000001"))
  (gr_line (start 100 113) (end 100 82)
    (stroke (width 0.1) (type default)) (layer "Edge.Cuts") (uuid "40000007-0000-0000-0000-000000000001"))
  (gr_arc (start 100 82) (mid 100.586 80.586) (end 102 80)
    (stroke (width 0.1) (type default)) (layer "Edge.Cuts") (uuid "40000008-0000-0000-0000-000000000001"))

  ;; ================================================================
  ;; MOUNTING HOLES (M2, 4 corners)
  ;; ================================================================
  (footprint "MountingHole:MountingHole_2.2mm_M2" (layer "F.Cu")
    (uuid "50000001-0000-0000-0000-000000000001")
    (at 103 83)
    (property "Reference" "H1" (at 0 -2.5 0) (layer "F.SilkS") (uuid "50000001-0001-0000-0000-000000000001") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "MountingHole" (at 0 2.5 0) (layer "F.Fab") (uuid "50000001-0002-0000-0000-000000000001") (effects (font (size 1 1) (thickness 0.15))))
    (pad "" thru_hole circle (at 0 0) (size 4.4 4.4) (drill 2.2) (layers "*.Cu" "*.Mask"))
  )
  (footprint "MountingHole:MountingHole_2.2mm_M2" (layer "F.Cu")
    (uuid "50000002-0000-0000-0000-000000000001")
    (at 147 83)
    (property "Reference" "H2" (at 0 -2.5 0) (layer "F.SilkS") (uuid "50000002-0001-0000-0000-000000000001") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "MountingHole" (at 0 2.5 0) (layer "F.Fab") (uuid "50000002-0002-0000-0000-000000000001") (effects (font (size 1 1) (thickness 0.15))))
    (pad "" thru_hole circle (at 0 0) (size 4.4 4.4) (drill 2.2) (layers "*.Cu" "*.Mask"))
  )
  (footprint "MountingHole:MountingHole_2.2mm_M2" (layer "F.Cu")
    (uuid "50000003-0000-0000-0000-000000000001")
    (at 103 112)
    (property "Reference" "H3" (at 0 -2.5 0) (layer "F.SilkS") (uuid "50000003-0001-0000-0000-000000000001") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "MountingHole" (at 0 2.5 0) (layer "F.Fab") (uuid "50000003-0002-0000-0000-000000000001") (effects (font (size 1 1) (thickness 0.15))))
    (pad "" thru_hole circle (at 0 0) (size 4.4 4.4) (drill 2.2) (layers "*.Cu" "*.Mask"))
  )
  (footprint "MountingHole:MountingHole_2.2mm_M2" (layer "F.Cu")
    (uuid "50000004-0000-0000-0000-000000000001")
    (at 147 112)
    (property "Reference" "H4" (at 0 -2.5 0) (layer "F.SilkS") (uuid "50000004-0001-0000-0000-000000000001") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "MountingHole" (at 0 2.5 0) (layer "F.Fab") (uuid "50000004-0002-0000-0000-000000000001") (effects (font (size 1 1) (thickness 0.15))))
    (pad "" thru_hole circle (at 0 0) (size 4.4 4.4) (drill 2.2) (layers "*.Cu" "*.Mask"))
