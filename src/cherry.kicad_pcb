  ;; ================================================================
  ;; SILKSCREEN - Board info and component placement guide
  ;; ================================================================
  (gr_text "Cherry" (at 125 82.5) (layer "F.SilkS") (uuid "60000001-0000-0000-0000-000000000001")
    (effects (font (size 2 2) (thickness 0.3)) (justify left))
  )
  (gr_text "NextMicon" (at 125 114) (layer "F.SilkS") (uuid "60000002-0000-0000-0000-000000000001")
    (effects (font (size 1 1) (thickness 0.15)) (justify left))
  )

  ;; Component placement guide (silkscreen text)
  ;; USB-C connector: left edge, centered vertically
  (gr_text "USB-C" (at 103 97.5) (layer "F.SilkS") (uuid "60000010-0000-0000-0000-000000000001")
    (effects (font (size 0.8 0.8) (thickness 0.12)) (justify left))
  )
  ;; FT2232H: center-left area
  (gr_text "U1" (at 113 97.5) (layer "F.SilkS") (uuid "60000011-0000-0000-0000-000000000001")
    (effects (font (size 0.8 0.8) (thickness 0.12)))
  )
  ;; iCE40: center-right area
  (gr_text "U2" (at 130 97.5) (layer "F.SilkS") (uuid "60000012-0000-0000-0000-000000000001")
    (effects (font (size 0.8 0.8) (thickness 0.12)))
  )
  ;; SPI Flash: near iCE40, lower
  (gr_text "U3" (at 130 107) (layer "F.SilkS") (uuid "60000013-0000-0000-0000-000000000001")
    (effects (font (size 0.8 0.8) (thickness 0.12)))
  )
  ;; LDOs: top area
  (gr_text "3.3V" (at 118 87) (layer "F.SilkS") (uuid "60000014-0000-0000-0000-000000000001")
    (effects (font (size 0.8 0.8) (thickness 0.12)))
  )
  (gr_text "1.2V" (at 128 87) (layer "F.SilkS") (uuid "60000015-0000-0000-0000-000000000001")
    (effects (font (size 0.8 0.8) (thickness 0.12)))
  )
  ;; GPIO Header: right edge
  (gr_text "GPIO" (at 145 97.5) (layer "F.SilkS") (uuid "60000016-0000-0000-0000-000000000001")
    (effects (font (size 0.8 0.8) (thickness 0.12)))
  )

  ;; ================================================================
  ;; GROUND POUR (B.Cu) - Full ground plane on back copper
  ;; ================================================================
  (zone (net 1) (net_name "GND") (layer "B.Cu") (uuid "70000001-0000-0000-0000-000000000001")
    (hatch edge 0.5)
    (connect_pads (clearance 0.3))
    (min_thickness 0.2)
    (fill yes (thermal_gap 0.5) (thermal_bridge_width 0.5))
    (polygon
      (pts
        (xy 100 80) (xy 150 80) (xy 150 115) (xy 100 115)
      )
    )
  )

  ;; ================================================================
  ;; COMPONENT PLACEMENT GUIDE (text notes on Fab layer)
  ;; ================================================================
  ;; Approximate component positions for PCB layout:
  ;;
  ;; PLACEMENT STRATEGY (50mm x 35mm board):
  ;;
  ;; TOP EDGE (y=80-88):
  ;;   - LDO 3.3V (U4) at ~(118, 85)
  ;;   - LDO 1.2V (U5) at ~(128, 85)
  ;;   - Power decoupling caps nearby
  ;;
  ;; LEFT EDGE (x=100-108):
  ;;   - USB-C connector (J1) at ~(100, 97.5), edge-mounted
  ;;   - Ferrite bead (FB1) near USB connector
  ;;
  ;; CENTER-LEFT (x=108-120):
  ;;   - FT2232HL (U1) at ~(113, 97.5)
  ;;   - 12MHz crystal (Y1) near OSCI/OSCO pins
  ;;   - Crystal load caps (C13-C14) near crystal
  ;;   - FT2232H decoupling caps (C1-C4) near power pins
  ;;
  ;; CENTER-RIGHT (x=125-138):
  ;;   - iCE40LP8K (U2) at ~(130, 97.5)
  ;;   - iCE40 decoupling caps (C5-C8) near power pins
  ;;   - W25Q32 Flash (U3) at ~(130, 107)
  ;;   - Flash decoupling cap (C9) near flash
  ;;
  ;; RIGHT EDGE (x=140-150):
  ;;   - GPIO header (J2) at ~(146, 97.5), edge-mounted
  ;;   - LEDs (D1-D4) near header
  ;;   - Buttons (SW1-SW2) near header
  ;;
  ;; BOTTOM LAYER:
  ;;   - Full GND pour
  ;;   - Additional routing as needed

  (gr_text "COMPONENT PLACEMENT:\nJ1(USB-C): left edge\nU1(FT2232H): center-left\nU2(iCE40): center-right\nU3(Flash): below U2\nU4(3.3V): top center-left\nU5(1.2V): top center-right\nJ2(GPIO): right edge"
    (at 125 97.5) (layer "F.Fab") (uuid "80000001-0000-0000-0000-000000000001")
    (effects (font (size 1 1) (thickness 0.15)) (justify left))
  )
)
